# No env vars required for local dev — Vite proxies /api to http://localhost:3000
# Add production-specific overrides here as needed

# Action Cable WebSocket URL (defaults to ws://localhost:3000/cable if not set)
# VITE_CABLE_URL=ws://localhost:3000/cable

# ---------------------------------------------------------------------------
# OIDC / Authentication (Phase 6.3)
# Point at your OIDC provider (e.g. the Dex stub used in Phase 6.1).
# ---------------------------------------------------------------------------
# VITE_OIDC_AUTHORITY=http://localhost:5556/dex
# VITE_OIDC_CLIENT_ID=mordors-edge-frontend
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# ---------------------------------------------------------------------------
# Dev auth bypass (development only)
# Set to "true" alongside DEV_AUTH_BYPASS=true on the backend to enable the
# "Dev Login" button on the login page.  This skips OIDC entirely and
# authenticates as dev@mordors-edge.local.
# NEVER set this to "true" in production builds.
# ---------------------------------------------------------------------------
# VITE_DEV_AUTH_BYPASS=true
